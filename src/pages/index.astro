---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Home";
const description = "Let's check where this goes to";
const permalink = Astro.site.href;
---

<BaseLayout title={title} description={description} permalink={permalink}>
  <div class="home-container">
    <div class="home-copy">
      <h1>Hi, I'm Math!</h1>
      <p>
        And this is my digital garden. I created it for personal use, to keep
        track of my learnings and be able to consult my notes from anywhere. But
        maybe it will also be useful to you!
      </p>
      <p>
        I built this website with <a href="https://astro.build/">Astro</a>.
        <br />
        Astro allows you to create fast web applications thanks to its island architecture:
        it renders HTML and only sends Javascript components to the browser when
        necessary. It's like going back to pure HTML/CSS/JQuery websites but with
        the comfort of a structured codebase like in modern JS Frameworks.
      </p>
      <p>
        This site is built for fun and for learning. I played with css
        animations such as this one where you can <button class="make-it-rain"
          >make it rain</button
        > on your screen.
      </p>
    </div>
  </div>

  <script>
    import { range, random } from "lodash";
    const rainButton = document.querySelector(".make-it-rain");

    rainButton!.addEventListener("mouseover", () => {
      const particlesContainer = document.querySelector(".home-container");

      range(10).forEach(() => {
        const rainDrop = document.createElement("div");
        rainDrop.innerText = "💧";
        rainDrop.classList.add("rain-drop");
        rainDrop.style.position = "absolute";
        rainDrop.style.top = "0px";
        rainDrop.style.left = random(0, 100) + "%";
        // TODO add random duration
        rainDrop.style.animation = `fall 1000ms`;
        particlesContainer!.appendChild(rainDrop);
      });
      // TODO remove particles once the animation is finished
    });
  </script>

  <style>
    @keyframes fall {
      to {
        transform: translateY(100vh);
      }
    }
    .home-container {
      position: relative;
      margin: 2em 0;
      min-height: 400px;
      /* TODO adapt icon color to theme */
      cursor:
        url("/assets/watering-can.svg") 16 16,
        auto;
    }

    .home-copy {
      flex: 1;
      padding: 0 1em;
    }

    .home-copy h1 {
      font-weight: 700;
      margin-bottom: 0.5em;
      line-height: 1.3;
    }

    .home-copy p {
      font-size: 1.4em;
    }

    button {
      all: unset;
      cursor: pointer;
      border: solid 0.12em var(--primary-color);
      border-radius: 0.36em;
      padding: 0.24em;
      box-shadow: inset 0 -0.12em 0 var(--primary-color);
      -webkit-transition:
        box-shadow 0.2s ease-in-out,
        color 0.2s ease-in-out;
      transition:
        box-shadow 0.2s ease-in-out,
        color 0.2s ease-in-out;
    }

    button:hover {
      box-shadow: inset 0 -2em 0 var(--primary-color);
      color: var(--text-main);
    }

    @media (max-width: 1200px) {
      p {
        font-size: 1.2em;
      }
    }

    @media (max-width: 800px) {
      .home-container {
        flex-direction: column;
      }

      .home-copy {
        flex: 0;
        padding-bottom: 2em;
        text-align: center;
      }
    }
  </style>
</BaseLayout>
