export async function getStaticPaths() {
  const posts = await getCollection("cicdPosts");
  return posts.map((p) => ({
    params: { slug: p.data.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const { title, slug, description, publishDate } = post.data;
const readingTimeEstimate = readingTime(post.body || "").text;
const permalink = `${Astro.site!.href}ci-cd/${slug}`;
const { Content } = await render(post);
---

<BaseLayout
  title={title}
  description={description}
  permalink={permalink}
  current="ci-cd"
>
  <header>
    <p>{publishDate} ~ {readingTimeEstimate}</p>
    <h1>{title}</h1>
    <hr />
  </header>
  <div class="container">
    <article class="content">
      <Content />
    </article>
    <hr />
    <Bio />
  </div>
</BaseLayout>

<style>
  header {
    text-align: center;
  }

  header h1 {
    margin-bottom: 0.7em;
  }

  header p {
    color: var(--text-secondary);
    text-transform: uppercase;
    font-family: var(--font-family-sans);
    font-weight: 600;
  }

  header hr {
    min-width: 100px;
    width: 30%;
  }
</style>
